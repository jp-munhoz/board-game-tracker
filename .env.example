# Postgres do Supabase. Use a connection string do "Session pooler"
# (Project Settings > Database > Connect > Session pooler), porta 5432 -
# evita o problema de conexao direta exigir IPv6.
#
# DATABASE_URL precisa estar no formato JDBC (prefixo jdbc:), nao na URI
# postgresql:// que o Supabase mostra por padrao.
DATABASE_URL=jdbc:postgresql://aws-0-<regiao>.pooler.supabase.com:5432/postgres
DATABASE_USERNAME=postgres.<seu-project-ref>
DATABASE_PASSWORD=

# access_token do app registrado em https://ludopedia.com.br/aplicativos
LUDOPEDIA_ACCESS_TOKEN=

# Porta HTTP. O Render injeta essa variavel automaticamente no deploy;
# em desenvolvimento local pode omitir (usa 8080 por padrao).
PORT=8080
